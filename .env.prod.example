# Copy this file to .env.prod, fill real values, then run:
#   set -a
#   source ./.env.prod
#   set +a
#   npm run start -- --config config/agent.canary.yaml
#   # Canary 通过后，再切到：
#   npm run start -- --config config/agent.prod.yaml

# Control plane
XAGENT_API_TOKEN=replace-with-a-long-random-token
API_HOST=127.0.0.1
PORT=8787

# Solana RPC
PRIMARY_RPC_URL=https://your-primary-rpc.example
HELIUS_RPC_URL=https://your-backup-rpc.example
GRPC_URL=

# Wallet
# Supported formats:
# 1. JSON array: [12,34,...]
# 2. base58 secret key
# 3. base64 secret key
WALLET_PRIVATE_KEY=
XAGENT_WALLET_KEY=

# Market / execution providers
EXECUTION_GATEWAY_URL=
EXECUTION_GATEWAY_API_KEY=
# gmgn-cli 会读取 GMGN_API_KEY；也可配置在 ~/.config/gmgn/.env
GMGN_API_KEY=
PROVIDER_A_URL=
PROVIDER_A_KEY=
PROVIDER_B_URL=
PROVIDER_B_KEY=
JUPITER_API_KEY=
JITO_AUTH_KEY=
METEORA_API_URL=https://dlmm.datapi.meteora.ag

# LLM
OPENAI_API_KEY=

# Persistence（SQLite 为本地文件，无需配置连接串）

# Valuation / notifications
SOL_PRICE_USD=
TG_BOT_TOKEN=
TG_CHAT_ID=
DISCORD_WEBHOOK=
