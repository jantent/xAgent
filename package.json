{
  "name": "xagent",
  "version": "0.1.0",
  "description": "基于 RFC 的 Meteora DLMM Agent 核心骨架实现",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:build": "tsc -p tsconfig.test.json",
    "test": "npm run test:build && node --test dist-test/tests",
    "verify": "npm run check && npm run build && npm run test",
    "start": "node dist/index.js",
    "start:once": "node dist/index.js --once",
    "start:no-api": "node dist/index.js --no-api",
    "wallet:secret": "node dist/tools/wallet-secret.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@meteora-ag/dlmm": "^1.9.4",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "hono": "^4.10.1",
    "sql.js": "^1.12.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^24.0.10",
    "@types/sql.js": "^1.4.11",
    "typescript": "^5.9.3"
  }
}
