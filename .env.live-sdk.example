# Copy this file to .env.live-sdk, fill real values, then run:
#   set -a
#   source ./.env.live-sdk
#   set +a
#   # 小额真钱联调建议优先使用：
#   npm run start -- --config config/agent.canary.yaml
#   # 仅做非 prod 风格联调时可继续用：
#   npm run start -- --config config/agent.live-sdk.yaml

# Control plane
XAGENT_API_TOKEN=replace-with-a-long-random-token
API_HOST=127.0.0.1
PORT=8787

# Solana RPC
PRIMARY_RPC_URL=https://your-primary-rpc.example
HELIUS_RPC_URL=https://your-backup-rpc.example
GRPC_URL=

# Wallet
# Supported formats:
# 1. JSON array: [12,34,...]
# 2. base58 secret key
# 3. base64 secret key
WALLET_PRIVATE_KEY=
XAGENT_WALLET_KEY=

# Live execution providers
EXECUTION_GATEWAY_URL=
EXECUTION_GATEWAY_API_KEY=
JUPITER_API_KEY=
JITO_AUTH_KEY=
METEORA_API_URL=https://dlmm.datapi.meteora.ag

# Market data providers
# gmgn-cli 会读取 GMGN_API_KEY；也可配置在 ~/.config/gmgn/.env
GMGN_API_KEY=
PROVIDER_A_URL=
PROVIDER_A_KEY=
PROVIDER_B_URL=
PROVIDER_B_KEY=

# LLM
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=  # 如需使用 Anthropic provider

# Persistence（SQLite 为本地文件，无需配置连接串）

# Notifications
TG_BOT_TOKEN=
TG_CHAT_ID=
DISCORD_WEBHOOK=
